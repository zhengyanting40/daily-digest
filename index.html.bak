<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>每日新闻速递 2026-06-02</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0d1117;color:#c9d1d9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;line-height:1.6;padding:20px}
.container{max-width:800px;margin:0 auto}
h1{font-size:24px;color:#f0f6fc;text-align:center;padding:20px 0 10px}
.date{font-size:17px;color:#8b949e;text-align:center;padding-bottom:20px;border-bottom:1px solid #30363d}
.section{background:#161b22;border:1px solid #30363d;border-radius:8px;padding:16px;margin-bottom:16px}
.section-title{font-size:19px;color:#f0f6fc;font-weight:600;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #30363d}
.section-title .icon{margin-right:8px}
.indices{display:grid;grid-template-columns:1fr 1fr;gap:10px 20px}
.indices .item{display:flex;justify-content:space-between;font-size:17px;padding:4px 0}
.indices .item .name{color:#8b949e}
.indices .item .val{font-weight:600}
.up{color:#F85149}
.down{color:#3FB950}
.neutral{color:#c9d1d9}
.tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:13px;margin:2px 4px 2px 0}
.tag-up{background:rgba(248,81,73,0.15);color:#F85149;border:1px solid rgba(248,81,73,0.3)}
.tag-down{background:rgba(63,185,80,0.15);color:#3FB950;border:1px solid rgba(63,185,80,0.3)}
.news-link{display:block;padding:6px 0;border-bottom:1px solid #21262d;font-size:15px;line-height:1.5}
.news-link:last-child{border-bottom:none}
.news-link a{color:#58a6ff;text-decoration:none}
.news-link a:hover{text-decoration:underline;color:#79c0ff}
.news-source{display:inline-block;font-size:12px;padding:1px 6px;border-radius:3px;margin-left:8px}
.news-source.eastmoney{background:rgba(88,166,255,0.12);color:#58a6ff}
.news-source.ft{background:rgba(248,81,73,0.12);color:#F85149}
.news-source.caixin{background:rgba(255,168,0,0.12);color:#ffaa00}
.stock-row{display:flex;justify-content:space-between;font-size:15px;padding:4px 0;border-bottom:1px solid #21262d}
.stock-row:last-child{border-bottom:none}
.stock-name{color:#c9d1d9}
.stock-lb{display:inline-block;font-size:11px;background:rgba(248,81,73,0.2);color:#F85149;padding:0 4px;border-radius:3px;margin-left:4px}
.sector-line{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px}
.footer{text-align:center;font-size:14px;color:#484f58;padding:20px 0}
.footer a{color:#58a6ff;text-decoration:none}
.footer a:hover{text-decoration:underline}
.summary-text{font-size:14px;line-height:1.8;color:#c9d1d9}
.summary-text strong{color:#f0f6fc}
.summary-text li{margin:4px 0;list-style:none;padding-left:0}
.summary-text li::before{content:"• ";color:#F85149}
@media(max-width:600px){
  body{padding:12px}
  h1{font-size:21px}
  .indices{grid-template-columns:1fr}
}
</style>
</head>
<body>
<div class="container">

